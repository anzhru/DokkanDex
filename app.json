{
  "expo": {
    "name": "DokkanDex",
    "slug": "dokkandex",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",

    "icon": "./assets/icon.png",

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },

    "ios": {
      "bundleIdentifier": "com.dokkandex.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "deploymentTarget": "16.0",
      "infoPlist": {
        "UIRequiresFullScreen": false,
        "NSCameraUsageDescription": "DokkanDex does not use the camera.",
        "NSPhotoLibraryUsageDescription": "DokkanDex does not access your photos."
      }
    },

    "android": {
      "package": "com.dokkandex.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#1a1a2e"
      }
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": []
  }
}
